# Entorno
APP_ENV=local
LOG_LEVEL=INFO
LOG_FILE=logs/botsaldos.log

# Google Sheets
GOOGLE_APPLICATION_CREDENTIALS=/ruta/segura/credenciales/service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET_NAME=Movimientos

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_STORAGE_STATE_PATH=playwright/.auth/storage_state.json

# APIs externas
EXTERNAL_API_TIMEOUT_SECONDS=20
