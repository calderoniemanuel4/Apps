# Entorno
APP_ENV=local
DRY_RUN=true
LOG_LEVEL=INFO
LOG_FILE=logs/botsaldos.log
LOCK_FILE=tmp/botsaldos.lock

# Google Sheets
GOOGLE_APPLICATION_CREDENTIALS=/ruta/segura/credenciales/service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET_NAME=Cotizaciones

# Selenium
SELENIUM_HEADLESS=false
SELENIUM_PAGE_LOAD_TIMEOUT_MS=30000
SELENIUM_WINDOW_WIDTH=1280
SELENIUM_WINDOW_HEIGHT=720
SELENIUM_ACCEPT_LANGUAGE=es-AR,es;q=0.9,en;q=0.8
SELENIUM_USER_AGENT=
SELENIUM_LAUNCH_ARGS=--disable-http2

# Santander Personas
SANTANDER_ENABLED=false
SANTANDER_LOGIN_URL=https://www2.personas.santander.com.ar/obp-webapp/angular/#!/login
SANTANDER_POST_LOGIN_URL=https://www2.personas.santander.com.ar/obp-webapp/angular/#!/home
SANTANDER_USERNAME=
SANTANDER_PASSWORD=
SANTANDER_USERNAME_SELECTOR=
SANTANDER_PASSWORD_SELECTOR=
SANTANDER_SUBMIT_SELECTOR=
SANTANDER_INPUT_MODE=direct
SANTANDER_SUBMIT_STRATEGY=click
SANTANDER_TYPE_DELAY_MS=60
SANTANDER_BALANCE_XPATH=
SANTANDER_LOGOUT_SELECTOR=
SANTANDER_LOGOUT_CONFIRM_SELECTOR=
SANTANDER_LOGOUT_SUCCESS_URL=https://www.santander.com.ar/personas/logout-plan-sueldo
SANTANDER_LOGOUT_TIMEOUT_MS=3000
SANTANDER_LOGIN_ERROR_SELECTOR=
SANTANDER_OFFLINE_SELECTOR=
SANTANDER_MAX_LOGIN_ATTEMPTS=2
SANTANDER_ATTEMPT_STATE_FILE=tmp/santander_login_attempts.json

# APIs externas
EXTERNAL_API_TIMEOUT_SECONDS=20
EXTERNAL_API_DOLLAR_QUOTE_URL=https://dolarapi.com/v1/dolares/oficial
